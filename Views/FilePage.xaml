<Page x:Class="StoraDesktop.Views.FilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Back" Click="OnBack" Margin="0,0,6,0" MinWidth="48" />
            <Button Grid.Column="1" Content="Upload" Click="OnUpload" Margin="0,0,6,0" />
            <Button Grid.Column="2" Content="Share" Click="OnShare" Margin="0,0,4,0" MinWidth="36" FontSize="12" />
            <Button Grid.Column="3" Content="Copy" Click="OnCopy" Margin="0,0,4,0" MinWidth="36" FontSize="12" />
            <Button Grid.Column="4" Content="Cut" Click="OnCut" Margin="0,0,4,0" MinWidth="36" FontSize="12" />
            <Button Grid.Column="5" Content="Paste" Click="OnPaste" Margin="0,0,4,0" MinWidth="36" FontSize="12"
                    IsEnabled="{x:Bind VM.HasClipboard, Mode=OneWay}" />
            <Button Grid.Column="6" Content="Del" Click="OnBatchDelete" Margin="0,0,4,0" MinWidth="36" FontSize="12" />
            <TextBlock Grid.Column="7" Text="{x:Bind VM.CurrPath, Mode=OneWay}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14" />
            <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                <TextBlock Text="{x:Bind VM.SelectedCount, Mode=OneWay}" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" FontWeight="Bold" />
                <TextBlock Text="selected" VerticalAlignment="Center" Opacity="0.6" />
                <Button Content="Clear" Click="OnClearSelection" MinWidth="40" Height="28" FontSize="11" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#1B5E20" Padding="8" Visibility="{x:Bind VM.ShowUploadPanel, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind VM.UploadStatus, Mode=OneWay}" Foreground="White" VerticalAlignment="Center" />
            <ProgressBar Grid.Column="1" Value="{x:Bind VM.UploadProgress, Mode=OneWay}" VerticalAlignment="Center" Height="12" />
        </Grid>

        <ListView x:Name="FileListView" Grid.Row="2"
                  ItemsSource="{x:Bind VM.Files, Mode=OneWay}"
                  AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
                  DoubleTapped="OnDoubleTap" RightTapped="OnRightTap"
                  SelectionMode="Multiple">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Grid Padding="8,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Icon}" FontSize="18" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind CategoryIcon}" FontSize="12" VerticalAlignment="Center" Opacity="0.5" />
                        <TextBlock Grid.Column="2" Text="{x:Bind Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="4" Text="{x:Bind UpdatedAt}" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" VerticalAlignment="Bottom" Height="36"
              Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
              Visibility="{x:Bind VM.IsLoading, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind VM.IsLoading, Mode=OneWay}" Width="18" Height="18" HorizontalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="3" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" Padding="8,4" FontSize="12" Opacity="0.6" />
        </Grid>
    </Grid>
</Page>
