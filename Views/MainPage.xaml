<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="StoraDesktop.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" Padding="12,8"
              Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="⬅ 返回"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="1" Content="⬆ 上传"
                    Command="{x:Bind ViewModel.UploadFileCommand}"
                    Margin="0,0,12,0" />

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center" FontSize="16"
                       Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}" />

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.CurrentUser.Username, Mode=OneWay}"
                           VerticalAlignment="Center" />
                <Button Content="登出"
                        Command="{x:Bind ViewModel.LogoutCommand}" />
            </StackPanel>
        </Grid>

        <!-- 文件列表 -->
        <ListView x:Name="FileListView"
                  Grid.Row="1" Margin="0,8,0,0"
                  ItemsSource="{x:Bind ViewModel.Files, Mode=OneWay}"
                  DoubleTapped="OnFileDoubleTapped"
                  RightTapped="OnFileRightTapped"
                  SelectionMode="Single">

            <!-- 右键菜单 -->
            <ListView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="⬇ 下载"
                                    Command="{x:Bind ViewModel.DownloadFileCommand}"
                                    CommandParameter="{x:Bind ViewModel.SelectedFile, Mode=OneWay}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="✂ 剪切" IsEnabled="False" />
                    <MenuFlyoutItem Text="📋 复制" IsEnabled="False" />
                    <MenuFlyoutItem Text="📄 粘贴" IsEnabled="False" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="🗑 删除"
                                    Command="{x:Bind ViewModel.DeleteFileCommand}"
                                    CommandParameter="{x:Bind ViewModel.SelectedFile, Mode=OneWay}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="ℹ 属性"
                                    Command="{x:Bind ViewModel.ShowPropertiesCommand}"
                                    CommandParameter="{x:Bind ViewModel.SelectedFile, Mode=OneWay}" />
                </MenuFlyout>
            </ListView.ContextFlyout>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Grid Padding="8,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" FontSize="20"
                                   Text="{x:Bind Icon}"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Name}"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind SizeDisplay}"
                                   VerticalAlignment="Center"
                                   Opacity="0.6" />

                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind UpdatedAt}"
                                   VerticalAlignment="Center"
                                   Opacity="0.6" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 加载动画 -->
        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="48" Height="48" />
        </Grid>

        <!-- 状态栏 -->
        <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
               Padding="12,4" FontSize="12" Opacity="0.6" />
            <TextBlock Grid.Column="1"
               Text="⏳ 加载更多..."
               Padding="0,4,12,4" FontSize="12" Opacity="0.6"
               Visibility="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>