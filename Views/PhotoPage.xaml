<Page x:Class="StoraDesktop.Views.PhotoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🖼 照片墙" FontSize="18" FontWeight="Bold" Padding="12,8" />
        <GridView x:Name="PhotoGrid" Grid.Row="1" ItemsSource="{x:Bind VM.Photos, Mode=OneWay}" SelectionMode="None" Padding="8">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Border Width="160" Height="160" Margin="4"
                            CornerRadius="8" PointerPressed="OnPhotoTap">
                        <Grid>
                            <TextBlock Text="🖼" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border VerticalAlignment="Bottom" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock Text="{x:Bind Name}" Padding="4" FontSize="12" Opacity="0.8"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" Padding="8,4" FontSize="12" Opacity="0.6" />
        </Grid>
    </Grid>
</Page>
