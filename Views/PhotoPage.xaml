<Page x:Class="StoraDesktop.Views.PhotoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Refresh" Click="OnRefresh" MinWidth="60" />
            <TextBlock Grid.Column="1" Text="Photo Wall" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
            <TextBlock Grid.Column="2" Text="{x:Bind VM.Status, Mode=OneWay}" VerticalAlignment="Center" Opacity="0.6" />
        </Grid>

        <Grid Grid.Row="1" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
              Visibility="{x:Bind VM.HasSelection, Mode=OneWay}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind VM.SelectedCount, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="selected" VerticalAlignment="Center" Opacity="0.6" />
                <Button Content="Download" Click="OnDownloadSelected" MinWidth="60" />
                <Button Content="Delete" Click="OnDeleteSelected" MinWidth="60" />
                <Button Content="Clear" Click="OnClearSelection" MinWidth="60" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" ViewChanged="OnScrollView">
            <GridView x:Name="PhotoGrid" ItemsSource="{x:Bind VM.Photos, Mode=OneWay}"
                      SelectionMode="None" Padding="8" IsItemClickEnabled="True" ItemClick="OnPhotoClick">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="0" ItemWidth="180" ItemHeight="180" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}"
                                PointerPressed="OnPhotoPointerPressed">
                            <Grid>
                                <TextBlock Text="🖼" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Border VerticalAlignment="Bottom" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                                    <TextBlock Text="{x:Bind Name}" Padding="4" FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>

        <Grid Grid.Row="2" Background="#CC000000" Visibility="{x:Bind VM.ShowPreview, Mode=OneWay}"
              PointerPressed="OnPreviewBgClick">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀" Click="OnPrevPhoto" Width="48" Height="48"
                    VerticalAlignment="Center" Margin="12,0,0,0" FontSize="20" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind VM.SelectedPhoto.Name, Mode=OneWay}" Foreground="White" FontSize="16"
                           TextAlignment="Center" />
                <TextBlock Text="{x:Bind VM.SelectedPhoto.SizeDisplay, Mode=OneWay}" Foreground="Gray"
                           FontSize="13" TextAlignment="Center" />
                <TextBlock Text="{x:Bind VM.SelectedPhoto.UpdatedAt, Mode=OneWay}" Foreground="Gray"
                           FontSize="12" TextAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="2" Content="▶" Click="OnNextPhoto" Width="48" Height="48"
                    VerticalAlignment="Center" Margin="0,0,12,0" FontSize="20" />
        </Grid>

        <TextBlock Grid.Row="3" Padding="8,4" FontSize="12" Opacity="0.6"
                   Text="Click to preview | Right-click to select" />
    </Grid>
</Page>
