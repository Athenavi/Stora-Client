<Page x:Class="StoraDesktop.Views.SharePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🔗 我的分享" FontSize="18" FontWeight="Bold" Padding="12,8" />
        <ListView x:Name="ShareList" Grid.Row="1" ItemsSource="{x:Bind VM.Shares, Mode=OneWay}" RightTapped="OnRightTap">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ShareItem">
                    <Grid Padding="8,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{x:Bind CreatedAt}" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="2" Text="{x:Bind DownloadCount}" Opacity="0.6" FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" Padding="8,4" FontSize="12" Opacity="0.6" />
        </Grid>
    </Grid>
</Page>
