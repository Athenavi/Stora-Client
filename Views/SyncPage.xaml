<Page x:Class="StoraDesktop.Views.SyncPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <Storyboard x:Name="SyncFlashStoryboard">
            <ColorAnimation Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                            From="Transparent" To="#3322BB66" Duration="0:0:0.3"
                            AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="360">
            <StackPanel Padding="16" Spacing="8">
                <TextBlock Text="Sync Drive Settings" FontSize="20" FontWeight="Bold" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Local Folder:" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{x:Bind VM.LocalPath, Mode=OneWay}" IsReadOnly="True" PlaceholderText="Select sync folder" />
                    <Button Grid.Column="2" Content="Browse" Command="{x:Bind VM.SelectFolderCommand}" />
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sync interval:" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" ItemsSource="{x:Bind VM.IntervalOptions}" SelectedIndex="{x:Bind VM.IntervalIndex, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Conflict mode:" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" ItemsSource="{x:Bind VM.ConflictOptions}" SelectedIndex="{x:Bind VM.ConflictIndex, Mode=TwoWay}" />
                </Grid>

                <TextBox Header="Whitelist (comma-sep, empty=all)" Text="{x:Bind VM.WhitelistText, Mode=TwoWay}" PlaceholderText="*.docx,*.pdf" />
                <TextBox Header="Blacklist (comma-sep)" Text="{x:Bind VM.BlacklistText, Mode=TwoWay}" PlaceholderText="*.tmp,~$*" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{x:Bind VM.ButtonText, Mode=OneWay}"
                            Command="{x:Bind VM.ToggleSyncCommand}"
                            Style="{StaticResource AccentButtonStyle}" Height="36" MinWidth="120" />
                    <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" VerticalAlignment="Center" Opacity="0.7" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <ListView x:Name="SyncList" Grid.Row="1" ItemsSource="{x:Bind VM.Files, Mode=OneWay}" Margin="4,4,0,0"
                  DoubleTapped="OnFileDoubleTap" Visibility="{x:Bind VM.HasFiles, Mode=OneWay}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SyncFileState">
                    <Grid x:Name="ItemGrid" Padding="8,4" ColumnSpacing="8">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SyncStates">
                                <VisualState x:Name="Syncing">
                                    <VisualState.Setters>
                                        <Setter Target="ItemGrid.Background" Value="#3322BB66" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Default" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind StatusIcon}" FontSize="16" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Error}" FontSize="11" Foreground="#E81123" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="3" Text="{x:Bind Direction}" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
