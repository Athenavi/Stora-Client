<Page x:Class="StoraDesktop.Views.VaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="🔐 私密空间" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="➕ 新建" Click="OnCreate" />
        </Grid>

        <!-- 保险箱列表 -->
        <ListView x:Name="VaultList" Grid.Row="1" ItemsSource="{x:Bind VM.Vaults, Mode=OneWay}"
                  DoubleTapped="OnUnlock">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:VaultItem">
                    <Grid Padding="8,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔒" FontSize="20" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind CreatedAt}" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind ItemCount}" VerticalAlignment="Center" Opacity="0.6" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" Padding="8,4" FontSize="12" Opacity="0.6" />
        </Grid>
    </Grid>
</Page>
