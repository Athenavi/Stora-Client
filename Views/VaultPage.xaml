<Page x:Class="StoraDesktop.Views.VaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:StoraDesktop.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <!-- Vault List View -->
        <Grid Visibility="{x:Bind VM.IsListView, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Refresh" Click="OnRefresh" MinWidth="60" />
                <TextBlock Grid.Column="1" Text="Vaults" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
            </Grid>

            <StackPanel Grid.Row="1" Padding="12,8" Spacing="8">
                <TextBox PlaceholderText="Vault name" Text="{x:Bind VM.VaultName, Mode=TwoWay}" />
                <PasswordBox PlaceholderText="Password (min 6 chars)" Password="{x:Bind VM.VaultPwd, Mode=TwoWay}" />
                <PasswordBox PlaceholderText="Confirm password" Password="{x:Bind VM.VaultConfirm, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Create Vault" Command="{x:Bind VM.CreateVaultCommand}" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>

            <ListView Grid.Row="2" ItemsSource="{x:Bind VM.Vaults, Mode=OneWay}" DoubleTapped="OnVaultDoubleTap"
                      RightTapped="OnVaultRightTap" SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:VaultItem">
                        <Grid Padding="8,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔒" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind CreatedAt}" FontSize="12" Opacity="0.6" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="Unlock" Click="OnUnlockClick"
                                    Tag="{x:Bind Id}" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="3" Padding="8,4" FontSize="12" Opacity="0.6" Text="{x:Bind VM.Status, Mode=OneWay}" />
        </Grid>

        <!-- Unlock View -->
        <StackPanel Visibility="{x:Bind VM.IsUnlockView, Mode=OneWay}"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="40">
            <TextBlock Text="🔒" FontSize="64" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind VM.VaultName, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
            <PasswordBox PlaceholderText="Password" Password="{x:Bind VM.VaultPwd, Mode=TwoWay}" Width="300" />
            <Button Content="Unlock" Command="{x:Bind VM.UnlockCommand}" Style="{StaticResource AccentButtonStyle}" Width="160" />
            <Button Content="Back" Click="OnBackToList" />
            <TextBlock Text="{x:Bind VM.Status, Mode=OneWay}" Opacity="0.6" />
        </StackPanel>

        <!-- Files View -->
        <Grid Visibility="{x:Bind VM.IsFilesView, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Back" Click="OnBackToList" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="{x:Bind VM.VaultName, Mode=OneWay}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="🔓 Unlocked" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.6" FontSize="12" />
                <Button Grid.Column="3" Content="Lock" Click="OnLock" Margin="0,0,8,0" />
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{x:Bind VM.VaultFiles, Mode=OneWay}"
                      RightTapped="OnFileRightTap" SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:VaultFileItem">
                        <Grid Padding="8,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📄" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2" Padding="8,4" FontSize="12" Opacity="0.6" Text="{x:Bind VM.Status, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
